# Supabase Configuration
# Get from: https://supabase.com/dashboard/project/YOUR_PROJECT/settings/api
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here

# Gemini AI Configuration
# Get from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key-here

# Instagram API Configuration
# Get from: https://developers.facebook.com/apps/YOUR_APP_ID/instagram-basic-display/
INSTAGRAM_APP_ID=your-instagram-app-id
INSTAGRAM_APP_SECRET=your-instagram-app-secret
INSTAGRAM_REDIRECT_URI=io.supabase.instainsight://login-callback

# Test Mode (optional): put your long-lived token here to skip OAuth during development
# Get from: https://developers.facebook.com/tools/explorer/
# INSTAGRAM_TEST_TOKEN=IGAA...
